---
import Layout from "../layouts/Layout.astro";
import ProjectSection from "../components/ProjectSection.astro";
import HeatmapBanner from "../components/HeatmapBanner.astro";
import ObjViewer from "../components/ObjViewer.astro";
import physicsModelData from "../assets/physicsmodel.obj?raw";
import spectaclesData from "../assets/spectacles.obj?raw";
import ContactItemComponent from "../components/ContactItemComponent.astro";
import "../assets/global.css";
---

<Layout>
  <div
    class="min-w-full min-h-full flex flex-col items-center justify-start py-8 open-sans gap-24 px-4 max-w-screen overflow-hidden"
  >
    <div class="flex flex-col gap-16 w-full max-w-4xl my-16">
      <div class="relative overflow-clip h-48">
        <HeatmapBanner />
      </div>
      <div class="flex flex-col w-full h-min gap-12 px-4">
        <div class="flex flex-col gap-2 pb-4 border-b border-neutral-200">
          <h1 class="text-4xl eb-garamond">
            Exploring Today, Building Tomorrow
          </h1>
          <div class="flex gap-2 text-lg">
            <span>Creative Technology</span>
            <span class="text-red-700">Lab</span>
            <span class="italic opacity-50">@ Cornell</span>
          </div>
        </div>
        <div class="flex gap-9 flex-col sm:flex-row">
          <p class="leading-7 text-neutral-500 w-full">
            We build exploratory projects that push the boundaries of Artificial
            Intelligence, Digital Storytelling, and Extended Reality. Student
            directed since 2008.
          </p>
          <p class="leading-7 text-neutral-500 w-full">
            We have open student work-study roles for curious, self-driven
            students. Faculty are also welcome; we partner on course resources
            and custom educational tools.
          </p>
        </div>
      </div>
      <div class="flex gap-6 mt-8 px-4 flex-col sm:flex-row sm:gap-4">
        <button
          class="button bg-blue-700 border-blue-400 hover:bg-blue-600 text-white kode-mono w-full sm:w-min text-nowrap h-12"
          >Apply for Student Role</button
        >
        <button
          class="button kode-mono w-full sm:w-min text-nowrap border-neutral-300 h-12"
          >Faculty Collaboration</button
        >
      </div>
    </div>

    <div class="flex flex-col w-full max-w-4xl">
      <div class="flex flex-col gap-2 pb-4 border-b border-neutral-200 px-4">
        <h2 class="text-2xl eb-garamond">Selected Projects</h2>
      </div>

      <ProjectSection
        credits={["Suriyash Malviya", "Grace Jin"]}
        client:visible
      >
        <Fragment slot="title">Physics EM Wave</Fragment>
        <Fragment slot="description">
          Built in partnership with Cornell's PHYS 1101 class. An interactive,
          3D visualization tool for eletrical and magnetic fields
        </Fragment>
        <Fragment slot="content">
          <ObjViewer class="w-full h-full" objData={physicsModelData} />
        </Fragment>
        <Fragment slot="button">
          <a href="#">
            <button class="button kode-mono">Open Project</button>
          </a>
        </Fragment>
      </ProjectSection>
      <ProjectSection credits={["George Margono", "Aiswarya Senthil"]}>
        <Fragment slot="title">Spectacles</Fragment>
        <Fragment slot="description">
          A series of ongoing experiments with Snap Inc.'s Spectacle AR Glasses,
          with applications ranging from real-time translation and language
          learning.
        </Fragment>
        <Fragment slot="content">
          <ObjViewer class="w-full h-full" objData={spectaclesData} />
        </Fragment>
        <Fragment slot="button">
          <a href="#">
            <button class="button kode-mono">Open Project</button>
          </a>
        </Fragment>
      </ProjectSection>
    </div>

    <div class="flex flex-col w-full max-w-4xl py-16 pb-48 gap-8">
      <div class="flex flex-col gap-2 pb-4 border-b border-neutral-200 px-4">
        <h2 class="text-2xl eb-garamond">
          Let's Build Something Amazing Together
        </h2>
      </div>

      <div class="h-min bg-neutral-50 flex flex-col py-12 px-4">
        <p class="px-8 pb-4">Reach out to us at:</p>
        <ul>
          <ContactItemComponent
            name="Parent Site"
            link="https://teaching.cornell.edu/learning-technologies/creative-technology-lab"
            shortenedLink="teaching.cornell.edu"
          />
          <ContactItemComponent
            name="Email"
            link="mailto:cti@cornell.edu"
            shortenedLink="cti@cornell.edu"
          />
          <ContactItemComponent
            name="Twitter"
            link="https://x.com/CTICornell"
            shortenedLink="@CTICornell"
          />
          <ContactItemComponent
            name="Instagram"
            link="https://www.instagram.com/cornellteaching"
            shortenedLink="@cornellteaching"
          />
        </ul>
      </div>
    </div>
  </div>
</Layout>
