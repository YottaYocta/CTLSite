---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  name: string;
  image: ImageMetadata | string;
  imageAlt?: string;
  website?: string;
  linkedin?: string;
  github?: string;
}

const { name, image, imageAlt = name, website, linkedin, github } = Astro.props;
---

<div class="flex flex-col gap-4 p-2 bg-[#f6f6f6]">
  {typeof image === "string" ? (
    <img
      src={image}
      alt={imageAlt}
      class="w-full object-cover border border-neutral-100"
    />
  ) : (
    <Image
      src={image}
      alt={imageAlt}
      class="w-full object-cover border border-neutral-100"
      layout="full-width"
    />
  )}
  <div class="flex w-full justify-between items-center">
    <p class="kode-mono text-sm text-neutral-800 text-nowrap">{name}</p>
    <div class="flex gap-2 w-min">
      {
        website && (
          <a href={website} target="_blank" rel="noopener noreferrer">
            <button class="button w-8 h-8 p-0 flex items-center justify-center">
              <svg
                class="w-4 h-4 text-neutral-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
            </button>
          </a>
        )
      }
      {
        linkedin && (
          <a href={linkedin} target="_blank" rel="noopener noreferrer">
            <button class="button w-8 h-8 p-0 flex items-center justify-center">
              <svg
                class="w-4 h-4 text-neutral-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </button>
          </a>
        )
      }
      {
        github && (
          <a href={github} target="_blank" rel="noopener noreferrer">
            <button class="button w-8 h-8 p-0 flex items-center justify-center">
              <svg
                class="w-4 h-4 text-neutral-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </button>
          </a>
        )
      }
    </div>
  </div>
</div>
